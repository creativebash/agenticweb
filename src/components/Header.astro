---
import { SITE_TITLE } from '../consts';
import HeaderLink from './HeaderLink.astro';
---

<header>
	<nav>
		<h2 class="site-title"><a href="/">{SITE_TITLE}</a></h2>
		<div class="internal-links">
			<HeaderLink href="/essays">Essays</HeaderLink>
			<HeaderLink href="/notes">Notes</HeaderLink>
			<HeaderLink href="/research">Research</HeaderLink>
			<HeaderLink href="/archive">Archive</HeaderLink>
			<HeaderLink href="/about">About</HeaderLink>
		</div>
	</nav>
</header>
<style>
	header {
		margin: 0;
		padding: 0 1em;
		background: white;
		box-shadow: 0 2px 8px rgba(var(--black), 5%);
	}
	h2 {
		margin: 0;
		font-size: 1em;
	}

	h2 a,
	h2 a.active {
		text-decoration: none;
	}
	nav {
		display: flex;
		align-items: center;
		justify-content: space-between;
		font-family: "Atkinson Hyperlegible", system-ui, sans-serif;
	}
	nav a {
		padding: 1em 0.5em;
		color: var(--black);
		border-bottom: 4px solid transparent;
		text-decoration: none;
	}
	nav a.active {
		text-decoration: none;
		border-bottom-color: var(--accent);
	}
	.site-title {
		font-family: "Newsreader", Georgia, serif;
		font-weight: 600;
	}
	@media (max-width: 720px) {
		nav {
			flex-direction: column;
			gap: 0.25em;
			padding: 0.5em 0;
		}
		nav a {
			padding: 0.35em 0.5em;
			font-size: 0.875rem;
		}
		.site-title {
			font-size: 1.1rem;
		}
	}
</style>
