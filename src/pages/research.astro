---
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';

const allPosts = await getCollection('blog');
const research = allPosts
	.filter((post) => post.id.startsWith('research/'))
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`Research — ${SITE_TITLE}`} description={SITE_DESCRIPTION} />
		<style>
			ul {
				list-style: none;
				padding: 0;
				margin: 0;
			}
			ul li {
				margin-bottom: 1.5em;
			}
			.title {
				margin: 0;
				color: var(--color-text);
				line-height: 1.3;
				font-size: 1.25em;
			}
			.date {
				margin: 0.25em 0 0 0;
				color: var(--color-muted);
				font-size: 0.875em;
			}
			.description {
				margin: 0.25em 0 0 0;
				color: var(--color-body);
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<h1>Research</h1>
			<p class="section-description">
				Breakdowns of tools, protocols, papers, frameworks, markets, and
				infrastructure.
			</p>
			{
				research.length > 0 ? (
					<ul>
						{
							research.map((post) => (
								<li>
									<a href={`/${post.id}/`}>
										<h3 class="title">{post.data.title}</h3>
										<p class="date">
											<FormattedDate date={post.data.pubDate} />
										</p>
										<p class="description">{post.data.description}</p>
									</a>
								</li>
							))
						}
					</ul>
				) : (
					<p>No research published yet.</p>
				)
			}
		</main>
		<Footer />
	</body>
</html>
<style>
	.section-description {
		color: var(--color-muted);
		margin-bottom: 2em;
	}
	ul a {
		text-decoration: none;
	}
	ul a .title:hover {
		text-decoration: underline;
	}
</style>
