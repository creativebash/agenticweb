---
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';

const allPosts = await getCollection('blog');
const notes = allPosts
	.filter((post) => post.id.startsWith('notes/'))
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`Notes — ${SITE_TITLE}`} description={SITE_DESCRIPTION} />
		<style>
			ul {
				list-style: none;
				padding: 0;
				margin: 0;
			}
			ul li {
				margin-bottom: 1.5em;
			}
			.title {
				margin: 0;
				color: rgb(var(--black));
				line-height: 1.3;
				font-size: 1.25em;
			}
			.date {
				margin: 0.25em 0 0 0;
				color: rgb(var(--gray));
				font-size: 0.875em;
			}
			.description {
				margin: 0.25em 0 0 0;
				color: rgb(var(--gray-dark));
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<h1>Notes</h1>
			<p class="section-description">
				Short observations, definitions, and emerging patterns from the edge
				of the agentic web.
			</p>
			{
				notes.length > 0 ? (
					<ul>
						{
							notes.map((post) => (
								<li>
									<a href={`/${post.id}/`}>
										<h3 class="title">{post.data.title}</h3>
										<p class="date">
											<FormattedDate date={post.data.pubDate} />
										</p>
										<p class="description">{post.data.description}</p>
									</a>
								</li>
							))
						}
					</ul>
				) : (
					<p>No notes published yet.</p>
				)
			}
		</main>
		<Footer />
	</body>
</html>
<style>
	.section-description {
		color: rgb(var(--gray));
		margin-bottom: 2em;
	}
</style>
